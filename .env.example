# ==== Armada 环境变量配置示例 ====
# 复制本文件为 .env 并填入真实值：cp .env.example .env
# .env 不会被提交到 git（已配置 .gitignore）

# --- Django 配置 ---
# 生成方法: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-django-secret-key-here

# 生产环境请设为 False
DJANGO_DEBUG=True

# 允许访问的主机名，多个用逗号分隔，如：example.com,10.0.0.1
DJANGO_ALLOWED_HOSTS=

# --- Kubeconfig 加密密钥 (Fernet) ---
# 用于加密存储在数据库中的集群 kubeconfig 内容
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 警告：此密钥一旦丢失，数据库中已导入的集群 kubeconfig 将无法解密！请妥善备份。
KUBECONFIG_ENCRYPTION_KEY=your-fernet-key-here
